            <label class="input-label">Message</label>
            <textarea style="min-height:140px">Hey {{first_name}}, hope you're doing well!

It's been a while since we last connected. Whether your timeline has changed or you're still exploring — we're always here when you're ready.

Whenever you'd like to chat, just book here: {{booking_link}}

Take care! 🏠
— {{agent_name}}, HomeUp</textarea>
          </div>
        </div>
      </div>
    </section>

  </main>
</div>

<div class="toast" id="toast">✓ Changes saved successfully</div>

<script>
  function showSection(id) {
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    event.currentTarget.classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function updateCount(el, countId) {
    const el2 = document.getElementById(countId);
    if (el2) el2.textContent = el.value.length;
  }

  // Init char counts
  document.querySelectorAll('textarea[id]').forEach(ta => {
    const countEl = document.getElementById(ta.id + '-count');
    if (countEl) countEl.textContent = ta.value.length;
  });

  function copyVar(el) {
    navigator.clipboard.writeText(el.textContent).then(() => {
      const orig = el.style.background;
      el.style.background = '#1a3a2a';
      el.style.color = '#3ecf8e';
      setTimeout(() => { el.style.background = ''; el.style.color = ''; }, 800);
    });
  }

  function addButton(containerId) {
    const container = document.getElementById(containerId);
    const rows = container.querySelectorAll('.wa-button-row');
    if (rows.length >= 3) { alert('WhatsApp allows a maximum of 3 buttons per message.'); return; }
    const row = document.createElement('div');
    row.className = 'wa-button-row';
    row.innerHTML = `<input type="text" placeholder="Button label"><button class="remove-btn" onclick="removeButton(this)">×</button>`;
    container.appendChild(row);
  }

  function removeButton(btn) {
    btn.parentElement.remove();
  }

  function removeFAQ(btn) {
    btn.closest('[data-faq]').remove();
  }

  function addFAQ() {
    const list = document.getElementById('faq-list');
    const card = document.createElement('div');
    card.className = 'message-card orange-outline';
    card.setAttribute('data-faq', '');
    card.innerHTML = `
      <div class="card-header">
        <div style="flex:1">
          <div class="input-group">
            <label class="input-label">Question / Trigger Phrase <span class="required">*</span></label>
            <input type="text" placeholder="E.g. Do you have properties in Damansara?">
          </div>
          <div class="input-group">
            <label class="input-label">Bot Response <span class="required">*</span></label>
            <textarea placeholder="Enter the bot's reply here..."></textarea>
          </div>
        </div>
        <button class="remove-btn" style="margin-top:0; flex-shrink:0" onclick="removeFAQ(this)">×</button>
      </div>`;
    list.appendChild(card);
    card.querySelector('input').focus();
  }

  function saveAll() {
    // Collect all data
    const data = {};
    document.querySelectorAll('textarea, input[type="text"]').forEach((el, i) => {
      if (el.id) data[el.id] = el.value;
    });
    localStorage.setItem('homeup-automation', JSON.stringify(data));
    showToast('✓ Changes saved successfully');
  }

  function exportConfig() {
    const config = collectConfig();
    const blob = new Blob([JSON.stringify(config, null, 2)], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'homeup-automations.json';
    a.click();
    showToast('⬇ Config exported!');
  }

  function collectConfig() {
    return {
      exported: new Date().toISOString(),
      comment_replies: {
        tiktok: document.getElementById('tiktok-comment')?.value,
        instagram: document.getElementById('ig-comment')?.value,
        facebook: document.getElementById('fb-comment')?.value,
      },
      dm_replies: {
        instagram: document.getElementById('ig-dm')?.value,
        facebook: document.getElementById('fb-dm')?.value,
        tiktok: document.getElementById('tiktok-dm')?.value,
      },
      whatsapp: {
        initial_message: document.getElementById('wa-initial-msg')?.value,
        booking_message: document.getElementById('booking-msg')?.value,
      },
      faqs: Array.from(document.querySelectorAll('[data-faq]')).map(card => ({
        trigger: card.querySelector('input[type="text"]')?.value,
        response: card.querySelector('textarea')?.value,
      })),
      reminders: {
        confirmation: document.getElementById('reminder-confirm')?.value,
        hours_24: document.getElementById('reminder-24h')?.value,
        hours_1: document.getElementById('reminder-1h')?.value,
        post_appointment: document.getElementById('reminder-post')?.value,
        instructions: document.getElementById('appt-instructions')?.value,
      },
      followups: {
        day_7: document.querySelector('#followups .timing-card:nth-child(1) textarea')?.value,
        day_30: document.querySelector('#followups .timing-card:nth-child(2) textarea')?.value,
        day_90: document.querySelector('#followups .timing-card:nth-child(3) textarea')?.value,
      }
    };
  }

  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  // Load saved data if exists
  try {
    const saved = localStorage.getItem('homeup-automation');
    if (saved) {
      const data = JSON.parse(saved);
      Object.entries(data).forEach(([id, val]) => {
        const el = document.getElementById(id);
        if (el) el.value = val;
      });
    }
  } catch(e) {}
</script>
</body>
</html>
