        <div class="section-title">Appointment Reminders</div>
        <div class="section-desc">Sent automatically after a lead books an appointment to reduce no-shows.</div>
      </div>

      <div class="var-hint">💡 Available variables:</div>
      <div class="variable-chips" style="margin-bottom:20px">
        <span class="var-chip" onclick="copyVar(this)">{{first_name}}</span>
        <span class="var-chip" onclick="copyVar(this)">{{appt_date}}</span>
        <span class="var-chip" onclick="copyVar(this)">{{appt_time}}</span>
        <span class="var-chip" onclick="copyVar(this)">{{agent_name}}</span>
        <span class="var-chip" onclick="copyVar(this)">{{meeting_link}}</span>
        <span class="var-chip" onclick="copyVar(this)">{{reschedule_link}}</span>
